{
	debug
	email sodjacksonville@gmail.com
}

# Test/Dev site - uses full platform
mechanicstaugustine.com, www.mechanicstaugustine.com {
	root * /var/www/ezlead-platform

	# Redirect CRM to single instance at ezlead4u.com (consolidated Jan 30, 2026)
	handle /crm/* {
		redir https://ezlead4u.com{uri} permanent
	}

	# Rewrite root to index.php for admin/buyer
	@indexPhp path /admin/ /buyer/
	rewrite @indexPhp {path}index.php

	@quote path /q/*
	@accept path /accept/*
	rewrite @accept /accept/index.php
	rewrite @quote /q/index.php

	# Video chat - /video/ROOM_ID -> /video/index.php
	@videochat1 path_regexp ^/video/([a-f0-9]{8})$
	rewrite @videochat1 /video/index.php

	php_fastcgi unix//run/php/php8.3-fpm.sock
	file_server
}

# Mobile Mechanic - primary mechanic site
mobilemechanic.best, www.mobilemechanic.best {
	root * /var/www/ezlead-platform

	# Redirect CRM to single instance at ezlead4u.com
	handle /crm/* {
		redir https://ezlead4u.com{uri} permanent
	}

	# Rewrite root to index.php for admin/buyer
	@indexPhp path /admin/ /buyer/
	rewrite @indexPhp {path}index.php

	@quote path /q/*
	@accept path /accept/*
	rewrite @accept /accept/index.php
	rewrite @quote /q/index.php

	# Video chat - /video/ROOM_ID -> /video/index.php
	@videochat2 path_regexp ^/video/([a-f0-9]{8})$
	rewrite @videochat2 /video/index.php

	php_fastcgi unix//run/php/php8.3-fpm.sock
	file_server
}

# HQ - Admin dashboard and buyer portal
ezlead4u.com, www.ezlead4u.com {
	root * /var/www/ezlead-hq

	# FastAPI backend
	@api path /v1/* /healthz
	handle @api {
		reverse_proxy localhost:8001
	}

	# PHP admin and buyer portals
	handle {
		@indexPhp path /admin/ /buyer/ /crm/
		rewrite @indexPhp {path}index.php

		php_fastcgi unix//run/php/php8.3-fpm.sock
		file_server
	}
}

